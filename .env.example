PORT=8080
NODE_ENV=development

# Internal API key for your admin endpoints (/api/*)
ADMIN_API_KEY=change_me

# WhatsApp Cloud API credentials
WHATSAPP_ACCESS_TOKEN=EAA...
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_BUSINESS_ACCOUNT_ID=1234567890
WHATSAPP_WEBHOOK_VERIFY_TOKEN=change_me_webhook_token
WHATSAPP_API_VERSION=v22.0

# Guardrails
MAX_DAILY_MESSAGES_GLOBAL=1000
MAX_DAILY_MESSAGES_PER_CONTACT=2
MIN_SECONDS_BETWEEN_MESSAGES_PER_CONTACT=1800
MAX_RETRIES=3
BASE_RETRY_DELAY_MS=3000
SEND_JITTER_MIN_MS=350
SEND_JITTER_MAX_MS=1200
FAILURE_WINDOW_SIZE=50
MAX_FAILURE_RATE_PERCENT=35
